<% layout("/layouts/boilerplate", { title: listing.title }) %>
<link href="https://api.mapbox.com/mapbox-gl-js/v2.15.0/mapbox-gl.css" rel="stylesheet">

<script>
    window.mapToken = "<%= process.env.MAP_TOKEN || '' %>";
    window.coordinates = <%- JSON.stringify(listing.geometry?.coordinates || []) %>;
    window.locationName = <%- JSON.stringify(listing.location || "Unknown") %>;
</script>

<div class="container-fluid mt-4">
    <!-- Title -->
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="display-5 fw-bold"><%= listing.title %></h1>
        </div>
    </div>

    <!-- Listing Card -->
    <div class="row justify-content-center mb-5">
        <div class="col-12 col-lg-8">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <img src="<%= listing.image.url %>" 
                     class="card-img-top show-img" 
                     alt="<%= listing.title %>"
                     style="height: 400px; object-fit: cover;">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-3">
                        <i class="bi bi-person-circle text-muted fs-4 me-2"></i>
                        <p class="card-text mb-0"><strong>Owned by <%= listing.owner.username %></strong></p>
                    </div>
                    <p class="card-text lead"><%= listing.description %></p> 
                    <h2 class="text-success fw-bold mb-3">₹ <%= listing.price.toLocaleString("en-IN") %></h2>
                    <div class="row">
                        <div class="col-md-6">
                            <p class="card-text mb-1"><i class="bi bi-geo-alt-fill text-primary"></i> <%= listing.location %></p>
                        </div>
                        <div class="col-md-6">
                            <p class="card-text mb-0"><i class="bi bi-globe text-muted"></i> <%= listing.country %></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Owner Buttons -->
    <% if(currUser && listing.owner._id.equals(currUser._id)) { %>
    <div class="row justify-content-center mb-5">
        <div class="col-12 col-md-6 d-flex gap-3 justify-content-center">
            <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark btn-lg px-4">
                <i class="bi bi-pencil-square me-2"></i>Edit
            </a>
            <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="d-inline">
                <button class="btn btn-danger btn-lg px-4" 
                        onclick="return confirm('Are you sure? This cannot be undone!')">
                    <i class="bi bi-trash3 me-2"></i>Delete
                </button>
            </form>
        </div>
    </div>
    <% } %>

    <!-- Reviews Section -->
    <div class="row justify-content-center mb-5">
        <div class="col-12 col-lg-10">
            <% if(currUser) { %>
            <div class="bg-light p-4 rounded-4 shadow-sm mb-5">
                <h3 class="mb-4">✨ Leave a Review</h3>
                <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">
                    <div class="mb-4">
                        <label for="rating" class="form-label fw-bold">Rating</label>
                        <fieldset class="starability-slot">
                            <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating"/>
                            <input type="radio" id="first-rate1" name="review[rating]" value="1"/>
                            <label for="first-rate1" title="Terrible - 1 star">1</label>
                            <input type="radio" id="first-rate2" name="review[rating]" value="2"/>
                            <label for="first-rate2" title="Not good - 2 stars">2</label>
                            <input type="radio" id="first-rate3" name="review[rating]" value="3"/>
                            <label for="first-rate3" title="Average - 3 stars">3</label>
                            <input type="radio" id="first-rate4" name="review[rating]" value="4"/>
                            <label for="first-rate4" title="Very good - 4 stars">4</label>
                            <input type="radio" id="first-rate5" name="review[rating]" value="5"/>
                            <label for="first-rate5" title="Amazing - 5 stars">5</label>
                        </fieldset>
                    </div>
                    <div class="mb-4">
                        <label for="comment" class="form-label fw-bold">Comments</label>
                        <textarea name="review[comment]" id="comment" class="form-control" rows="5" required></textarea>
                        <div class="invalid-feedback">Please add some comments!</div>
                    </div>
                    <button class="btn btn-outline-dark btn-lg px-4">Submit Review</button>
                </form>
            </div>
            <% } %>

            <!-- All Reviews -->
            <% if(listing.reviews.length > 0) { %>
            <h3 class="mb-4">📝 All Reviews (<%= listing.reviews.length %>)</h3>
            <div class="row g-4">
                <% for(review of listing.reviews) { %>
                <div class="col-lg-6 col-xl-4">
                    <div class="card h-100 shadow-sm border-0 rounded-3">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <h5 class="card-title mb-0">@<%= review.author.username %></h5>
                                <% if(currUser && review.author._id.equals(currUser._id)) { %>
                                <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" class="d-inline">
                                    <button class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete review?')">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                                <% } %>
                            </div>
                            <p class="starability-result mb-3 fs-5" data-rating="<%= review.rating %>"></p>
                            <p class="card-text"><%= review.comment %></p>
                        </div>
                    </div>
                </div>
                <% } %>
            </div>
            <% } else { %>
            <div class="text-center py-5">
                <h4>🤔 No reviews yet</h4>
                <p class="text-muted">Be the first to leave a review!</p>
            </div>
            <% } %>
        </div>
    </div>

    <!-- 🗺️ MAP SECTION - PERFECT RESPONSIVE + PINNING -->
    <div class="row justify-content-center mb-5 pb-5">
        <div class="col-12 col-lg-10">
            <h2 class="mb-4 text-center text-lg-start">📍 Where you'll be</h2>
            
            <!-- MAP CONTAINER - EXACT HEIGHT + RESPONSIVE -->
            <div id="map" 
                 class="w-100 rounded-4 shadow-lg border"
                 style="height: 450px; 
                        min-height: 400px; 
                        max-height: 500px;
                        border: 3px solid #dee2e6;
                        position: relative;
                        overflow: hidden;">
                
                <!-- Loading spinner -->
                <div id="map-loading" class="position-absolute top-50 start-50 translate-middle">
                    <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status">
                        <span class="visually-hidden">Loading map...</span>
                    </div>
                    <p class="mt-2 mb-0 fw-bold">Loading your location...</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Scripts at BOTTOM -->
<script src="https://api.mapbox.com/mapbox-gl-js/v2.15.0/mapbox-gl.js"></script>
<script src="/js/map.js"></script>
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">