<% layout("/layouts/boilerplate", { title: listing.title }) %>
<script>
    window.mapToken = "<%= process.env.MAP_TOKEN %>";
    window.coordinates = <%- JSON.stringify(listing.geometry?.coordinates || []) %>;
    window.locationName = <%- JSON.stringify(listing.location || "Unknown") %>;
</script>

<div class="row mt-4">
    <!-- Main content -->
    <div class="col-8 offset-2">
        <h1 class="mb-4"><%= listing.title %></h1>
        
        <!-- Listing Card -->
        <div class="card shadow-sm mb-5">
            <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="<%= listing.title %>">
            <div class="card-body">
                <p class="card-text mb-1"><i class="bi bi-person-circle"></i> Owned by <strong><%= listing.owner.username %></strong></p>
                <p class="card-text"><%= listing.description %></p> 
                <p class="card-text fs-3 fw-bold text-success mb-1">₹ <%= listing.price.toLocaleString("en-IN") %></p>
                <p class="card-text mb-1"><i class="bi bi-geo-alt"></i> <%= listing.location %>, <%= listing.country %></p>
            </div>
        </div>

        <!-- Owner Actions -->
        <% if(currUser && listing.owner._id.equals(currUser._id)) { %>
        <div class="d-flex gap-2 justify-content-center mb-5">
            <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark">
                <i class="bi bi-pencil"></i> Edit
            </a>
            <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="d-inline">
                <button class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this listing?')">
                    <i class="bi bi-trash"></i> Delete
                </button>
            </form>
        </div>
        <% } %>

        <!-- Reviews Section -->
        <div class="mb-5">
            <% if(currUser) { %>
            <hr class="my-5">
            <h3 class="mb-4">Leave a Review</h3>
            <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">
                <!-- Star rating -->
                <div class="mb-4">
                    <label for="rating" class="form-label">Rating</label>
                    <fieldset class="starability-slot">
                        <!-- Your existing star rating HTML -->
                    </fieldset>
                </div>
                
                <div class="mb-4">
                    <label for="comment" class="form-label">Comments</label>
                    <textarea name="review[comment]" id="comment" class="form-control" rows="5" required></textarea>
                    <div class="invalid-feedback">Please add some comments for your review</div>
                </div>
                <button type="submit" class="btn btn-outline-dark">Submit Review</button>
            </form>
            <% } %>

            <!-- Existing Reviews -->
            <% if(listing.reviews.length > 0) { %>
            <hr class="my-5">
            <h3>All Reviews (<%= listing.reviews.length %>)</h3>
            <div class="row g-4">
                <% for(review of listing.reviews) { %>
                <div class="col-lg-6">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <h5 class="card-title mb-0">@<%= review.author.username %></h5>
                                <% if(currUser && review.author._id.equals(currUser._id)) { %>
                                <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" class="d-inline">
                                    <button class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this review?')">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                                <% } %>
                            </div>
                            <p class="starability-result mb-3" data-rating="<%= review.rating %>"></p>
                            <p class="card-text"><%= review.comment %></p>
                        </div>
                    </div>
                </div>
                <% } %>
            </div>
            <% } else { %>
            <p class="text-muted mt-3">No reviews yet. Be the first to leave a review!</p>
            <% } %>
        </div>

        <!-- Map Section -->
        <div class="mb-5">
            <h3>Where you'll be</h3>
            <div id="map" style="height: 400px; border-radius: 10px; overflow: hidden;"></div>
        </div>
    </div>
</div>

<script src="/js/map.js"></script>
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">