<% layout("/layouts/boilerplate", { title: 'All Listings' }) %>

<style>
/* Mobile-First Responsive Design */
.airbnb-search {
  padding: 2rem 1rem;
  background: linear-gradient(135deg, #667eea 0%, #a143ff 100%);
  margin-bottom: 2rem;
}

.search-container {
  background: #fff;
  border-radius: 50px;
  box-shadow: 0 8px 32px rgba(0,0,0,0.15);
  overflow: hidden;
  width: 100%;
  max-width: 900px;
  margin: 0 auto;
}

.search-item {
  flex: 1;
  padding: 12px 16px;
  border-right: 1px solid #eee;
}

.search-item:last-child {
  border-right: none;
}

.search-item label {
  font-size: 0.75rem;
  font-weight: 600;
  color: #666;
  margin-bottom: 4px;
  display: block;
}

.search-item input {
  border: none;
  outline: none;
  font-size: 1rem;
  background: transparent;
  width: 100%;
}

.search-item input::placeholder {
  color: #999;
}

.divider {
  height: 40px;
  width: 1px;
  background: linear-gradient(to bottom, transparent, #ddd, transparent);
  margin: 0 8px;
}

.search-btn {
  background: linear-gradient(135deg, #ff385c, #e31c5d);
  border: none;
  color: white;
  border-radius: 50%;
  width: 48px;
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.3s ease;
  flex-shrink: 0;
  margin-right: 8px;
}

.search-btn:hover {
  transform: scale(1.05);
  box-shadow: 0 8px 25px rgba(255, 56, 92, 0.4);
}

/* Filters - Responsive Grid */
#filters {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
  justify-content: center;
  margin: 2rem 0;
  padding: 0 1rem;
}

.filter {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 1rem 1.5rem;
  border-radius: 2rem;
  background: #f8f9fa;
  transition: all 0.3s ease;
  text-decoration: none;
  color: inherit;
  min-width: 80px;
}

.filter:hover {
  background: #fff;
  transform: translateY(-4px);
  box-shadow: 0 8px 25px rgba(0,0,0,0.15);
  color: #ff385c;
}

.filter i {
  font-size: 1.5rem;
  margin-bottom: 0.5rem;
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.filter p {
  font-size: 0.85rem;
  font-weight: 500;
  margin: 0;
}

/* Tax Toggle - Responsive */
.tax-toggle {
  display: flex;
  align-items: center;
  padding: 0.75rem 1.5rem;
  border: 2px solid #dee2e6;
  border-radius: 2rem;
  background: #f8f9fa;
  transition: all 0.3s ease;
  white-space: nowrap;
}

.tax-toggle:hover {
  border-color: #ff385c;
  background: #fff;
}

.tax-toggle label {
  font-size: 0.9rem;
  font-weight: 500;
  margin-bottom: 0;
  cursor: pointer;
}

/* Listing Cards - Perfect Responsive */
.listing-link {
  text-decoration: none;
  color: inherit;
  transition: transform 0.2s ease;
}

.listing-link:hover .listing-card {
  transform: translateY(-8px);
}

.listing-card {
  border: none;
  border-radius: 1.5rem;
  overflow: hidden;
  box-shadow: 0 4px 20px rgba(0,0,0,0.1);
  transition: all 0.3s ease;
  height: 100%;
  background: #fff;
}

.listing-card:hover {
  box-shadow: 0 12px 40px rgba(0,0,0,0.15) !important;
}

.card-img-top {
  height: 220px;
  width: 100%;
  object-fit: cover;
  transition: transform 0.3s ease;
}

.listing-card:hover .card-img-top {
  transform: scale(1.05);
}

.card-body {
  padding: 1.25rem;
}

.card-text b {
  font-size: 1.1rem;
  color: #1f2937;
  display: block;
  margin-bottom: 0.5rem;
}

.card-text .price {
  font-size: 1.25rem;
  font-weight: 700;
  color: #059669;
  margin-bottom: 0.25rem;
}

.tax-info {
  display: none;
  font-size: 0.8rem;
  color: #6b7280;
}

/* Mobile Optimizations */
@media (max-width: 768px) {
  .search-container {
    flex-direction: column;
    border-radius: 16px;
    gap: 12px;
    padding: 16px;
  }
  
  .search-item {
    border-right: none !important;
    border-bottom: 1px solid #eee;
    padding: 12px 8px;
  }
  
  .search-item:last-child {
    border-bottom: none;
  }
  
  .divider {
    display: none;
  }
  
  #filters {
    flex-direction: column;
    align-items: stretch;
  }
  
  .filter {
    flex: 1 1 100px;
  }
}

@media (max-width: 576px) {
  .airbnb-search {
    padding: 1.5rem 0.5rem;
  }
  
  .search-btn {
    position: sticky;
    right: 8px;
    margin-right: 0;
  }
}
</style>

<!-- Airbnb Search Bar -->
<section class="airbnb-search">
  <div class="container-fluid">
    <form action="/listings" method="GET" class="search-container">
      <!-- Where -->
      <div class="search-item">
        <label>Where</label>
        <input type="text" name="location" placeholder="Search destinations" value="<%= location || '' %>">
      </div>

      <!-- Divider -->
      <div class="divider"></div>

      <!-- Dates -->
      <div class="search-item">
        <label>Check-in - Check-out</label>
        <input type="text" name="dates" placeholder="Add dates" value="<%= dates || '' %>">
      </div>

      <!-- Divider -->
      <div class="divider"></div>

      <!-- Guests/Service -->
      <div class="search-item">
        <label>Guests</label>
        <input type="text" name="guests" placeholder="Add guests" value="<%= guests || '' %>">
      </div>

      <!-- Search Button -->
      <button type="submit" class="search-btn">
        <i class="fas fa-search"></i>
      </button>
    </form>
  </div>
</section>

<!-- Filters Section -->
<section id="filters" class="container">
  <div class="row justify-content-center">
    <div class="col-12">
      <div class="d-flex flex-wrap justify-content-center gap-2 mb-4">
        <a href="/listings?category=trending" class="filter">
          <i class="fas fa-fire text-danger"></i>
          <p>Trending</p>
        </a>
        <a href="/listings?category=rooms" class="filter">
          <i class="fas fa-bed text-primary"></i>
          <p>Rooms</p>
        </a>
        <a href="/listings?category=cities" class="filter">
          <i class="fas fa-mountain-city text-info"></i>
          <p>Cities</p>
        </a>
        <a href="/listings?category=mountains" class="filter">
          <i class="fas fa-mountain text-success"></i>
          <p>Mountains</p>
        </a>
        <a href="/listings?category=camping" class="filter">
          <i class="fas fa-campground text-warning"></i>
          <p>Camping</p>
        </a>
      </div>
      
      <!-- Tax Toggle -->
      <div class="tax-toggle">
        <div class="form-check-reverse form-switch">
          <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
          <label class="form-check-label" for="switchCheckDefault">
            Display total incl. taxes
          </label>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Listings Grid -->
<section class="container-fluid px-3 px-md-4">
  <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-3 g-lg-4">
    <% for(let listing of allListings) { %>
      <div class="col">
        <a href="/listings/<%= listing._id %>" class="listing-link">
          <div class="card listing-card h-100">
            <img src="<%= listing.image.url %>" 
                 class="card-img-top" 
                 alt="<%= listing.title %>" 
                 loading="lazy">
            <div class="card-body">
              <h6 class="card-title fw-bold mb-2"><%= listing.title %></h6>
              <p class="card-text mb-1">
                <span class="price">₹<%= listing.price.toLocaleString("en-IN") %> <small>/night</small></span>
                <span class="tax-info">+ 18% GST</span>
              </p>
              <small class="text-muted"><%= listing.location %></small>
            </div>
          </div>
        </a>
      </div>
    <% } %>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Tax toggle functionality
  const taxSwitch = document.getElementById('switchCheckDefault');
  const taxInfos = document.querySelectorAll('.tax-info');
  
  taxSwitch.addEventListener('change', () => {
    taxInfos.forEach(info => {
      info.style.display = taxSwitch.checked ? 'inline' : 'none';
    });
  });
  
  // Smooth hover animations
  const cards = document.querySelectorAll('.listing-card');
  cards.forEach(card => {
    card.addEventListener('mouseenter', () => {
      card.style.transform = 'translateY(-4px)';
    });
    card.addEventListener('mouseleave', () => {
      card.style.transform = 'translateY(0)';
    });
  });
});
</script>